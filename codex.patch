+
+
+def count_html(path: Path) -> int:
+    if not path.exists():
+        return 0
+    return len(list(path.rglob("*.html")))
+
+
+def count_blog_posts(path: Path) -> int:
+    blog = path / "blog"
+    if not blog.exists():
+        return 0
+    count = 0
+    for p in blog.iterdir():
+        if p.is_dir() and re.fullmatch(r"p\d+", p.name):
+            if (p / "index.html").exists():
+                count += 1
+    return count
+
+
+def main() -> None:
