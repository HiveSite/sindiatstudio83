+        "",
+        "| Language | HTML files | Blog posts |",
+        "|---|---:|---:|",
+    ]
+
+    for lang in LANGS:
+        lang_dir = PAGES / lang
+        lines.append(f"| `{lang}` | {count_html(lang_dir)} | {count_blog_posts(lang_dir)} |")
+
+    sitemap = (PAGES / "sitemap.xml").read_text(encoding="utf-8", errors="ignore")
+    url_count = len(re.findall(r"<url>", sitemap))
